FLOWLENS_NODE_ID=flowlens-node-1
FLOWLENS_SERVER_ENDPOINT=http://127.0.0.1:8088/api/v1/agent/batches
FLOWLENS_AGENT_TOKEN=CHANGE_AGENT_TOKEN
FLOWLENS_SPOOL_DIR=/var/lib/flowlens-agent/spool
FLOWLENS_INTERFACE_COUNTERS_PATH=/proc/net/dev
FLOWLENS_INTERVAL=2s
FLOWLENS_NPM_LOG_GLOBS=/data/logs/proxy-host-*_access.log
FLOWLENS_CAPTURE_INTERFACES=CHANGE_CAPTURE_INTERFACE
FLOWLENS_DOCKER_ATTRIBUTION=disabled
